# Neon PostgreSQL (wajib diisi di Railway)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Groq AI API Key
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx

# URL frontend Vercel (isi setelah frontend di-deploy)
FRONTEND_URL=https://your-app.vercel.app

# Port (Railway set otomatis, tidak perlu diisi manual)
# PORT=5000
